# ── Copy this file to backend/.env and fill in real values ────────────────────
# docker compose reads this file automatically for ${VAR} substitutions.
# The backend service also loads ./backend/.env directly via env_file.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=false
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by the postgres service AND passed to the backend container.
POSTGRES_DB=agentic_workflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme          # change in production

# ── Ollama ────────────────────────────────────────────────────────────────────
# OLLAMA_BASE_URL is overridden per-service in docker-compose.yml;
# set it here only when running the backend outside Docker.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3:14b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# CHROMA_HOST / CHROMA_PORT are overridden per-service in docker-compose.yml.
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=knowledge_base

# ── RAG ───────────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=10
RERANKER_TOP_N=3
RERANKER_MODEL=BAAI/bge-reranker-large

# ── LangGraph ─────────────────────────────────────────────────────────────────
LANGGRAPH_CHECKPOINT_TABLE=checkpoints
LANGGRAPH_MAX_STEPS=20

# ── Human Approval ────────────────────────────────────────────────────────────
APPROVAL_TIMEOUT_SECONDS=3600
APPROVAL_WEBHOOK_URL=

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=agentic-workflow
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── LangSmith (optional) ──────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentic-workflow
